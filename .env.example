# Stack-wide docker compose configuration for docker-compose.all-services.yml.
#
# Copy to .env before deploying — docker compose reads .env, not .env.example:
#   cp .env.example .env
#
# Per-app settings live in each app's own .env.example; this file holds only the
# values the compose stack itself interpolates.

# Public HTTP entry point (nginx)
ORWELL_HTTP_PORT=8080

# Loki. Every server pushes its own app logs directly (packages/logger, LokiLogger) — there is
# no collector, so this value is handed to every Java service.
#
# LOKI_URL is the FULL push endpoint, including /loki/api/v1/push. It must point at the same
# Loki that apps/log-analyzer queries through Grafana (GRAFANA_LOKI_DATASOURCE_UID in
# apps/log-analyzer/.env.example) — if the two disagree, the analyzer queries an instance
# nothing writes to and silently reports no errors forever. Nothing checks this for you.
#
# Leave LOKI_URL empty to keep logs on the console only; services log a warning at startup so
# that choice is visible rather than silent. Credentials, if needed, belong in the URL
# (https://user:pass@host/...). LOKI_TENANT_ID sets X-Scope-OrgID for multi-tenant Loki.
LOKI_URL=http://loki:3100/loki/api/v1/push
LOKI_TENANT_ID=
