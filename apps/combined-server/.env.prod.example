# Combined server — production environment
# Hostnames should point to your production database and Redis instances.
# No local databases are started in production mode.
# Copy to .env.prod and fill in your production credentials.

COMBINED_SERVER_PORT=8080

AUTH_DATASOURCE_URL=jdbc:postgresql://your-auth-db-host:5432/auth?sslmode=require
AUTH_DATASOURCE_USERNAME=change-me
AUTH_DATASOURCE_PASSWORD=change-me

SPRING_DATASOURCE_URL=jdbc:postgresql://your-clippy-db-host:5432/clippy?sslmode=require
SPRING_DATASOURCE_USERNAME=change-me
SPRING_DATASOURCE_PASSWORD=change-me

AUTH_JPA_HIBERNATE_DDL_AUTO=validate
CLIPBOARD_JPA_HIBERNATE_DDL_AUTO=validate
JPA_JDBC_TIME_ZONE=UTC

CLIPPY_AUTH_BASE_URL=http://localhost:8080/auth
CLIPPY_AUTH_ROUTE_PREFIX=/auth
CLIPPY_SERVER_ROUTE_PREFIX=/klippy
JARVIS_SERVER_ROUTE_PREFIX=/jarvis
KEEBOARDER_SERVER_ROUTE_PREFIX=/keeboarder
WEBSOCKET_HOST=0.0.0.0
WEBSOCKET_PORT=8025
REDIS_HOST=your-redis-host
REDIS_PORT=6379

LOGGING_FILE_NAME=logs/combined-server.log

PROXY_STORAGE_PROVIDER=aws
PROXY_S3_BUCKET_NAME=change-me
PROXY_S3_REGION=us-east-1
