# Combined server — testing environment
# Hostnames reference docker service names in docker-compose.testing.yml.
# Copy to .env.testing and adjust as needed.

COMBINED_SERVER_PORT=8080

AUTH_DATASOURCE_URL=jdbc:postgresql://db-auth:5432/auth
AUTH_DATASOURCE_USERNAME=auth
AUTH_DATASOURCE_PASSWORD=auth

SPRING_DATASOURCE_URL=jdbc:postgresql://db-clippy:5432/clippy
SPRING_DATASOURCE_USERNAME=clippy
SPRING_DATASOURCE_PASSWORD=clippy

AUTH_JPA_HIBERNATE_DDL_AUTO=update
CLIPBOARD_JPA_HIBERNATE_DDL_AUTO=update
JPA_JDBC_TIME_ZONE=UTC

CLIPPY_AUTH_BASE_URL=http://localhost:8080/auth
CLIPPY_AUTH_ROUTE_PREFIX=/auth
CLIPPY_SERVER_ROUTE_PREFIX=/klippy
JARVIS_SERVER_ROUTE_PREFIX=/jarvis
KEEBOARDER_SERVER_ROUTE_PREFIX=/keeboarder
WEBSOCKET_HOST=0.0.0.0
WEBSOCKET_PORT=8025
REDIS_HOST=redis
REDIS_PORT=6379

LOGGING_FILE_NAME=logs/combined-server.log

PROXY_STORAGE_PROVIDER=aws
PROXY_S3_BUCKET_NAME=your-bucket-name
PROXY_S3_REGION=us-east-1
