# Log analyzer configuration
SERVER_ADDRESS=127.0.0.1
SERVER_PORT=9010
LOG_ANALYZER_POLL_INTERVAL_SECONDS=60
LOG_ANALYZER_LOOKBACK_SECONDS=300
LOG_ANALYZER_MAX_LOG_LINES=120
LOG_ANALYZER_ALERT_COOLDOWN_SECONDS=900

# Grafana config
GRAFANA_URL=http://127.0.0.1:3000
GRAFANA_API_TOKEN=
GRAFANA_LOKI_DATASOURCE_UID=

# Loki query payload
LOKI_QUERY={ } |~ "(?i)(error|exception|fatal|panic)"

# AI config
AI_API_URL=https://api.openai.com/v1/chat/completions
AI_API_KEY=
AI_MODEL=gpt-4o-mini
AI_TIMEOUT_SECONDS=30
MIN_IMPORTANCE_CONFIDENCE=0.7

# Alert service
ALERT_URL=http://127.0.0.1:9000/alerts
