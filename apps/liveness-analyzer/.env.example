# Liveness analyzer configuration
SERVER_ADDRESS=127.0.0.1
SERVER_PORT=9020
LIVENESS_CHECK_INTERVAL_SECONDS=5
LIVENESS_LOOKBACK_SECONDS=60
LIVENESS_THRESHOLD_SECONDS=15
LIVENESS_MAX_LOG_LINES=500
LIVENESS_ALERT_COOLDOWN_SECONDS=300

# Comma-separated client ids that must be alive (checked even if never seen in Loki)
LIVENESS_EXPECTED_CLIENTS=

# Grafana config (must point at the same Loki the servers push to via LOKI_URL)
GRAFANA_URL=http://127.0.0.1:3000
GRAFANA_API_TOKEN=
GRAFANA_LOKI_DATASOURCE_UID=

# Loki query selecting client heartbeat lines
LIVENESS_LOKI_QUERY={stream_type="app"} | json | message="Client heartbeat."

# Alert service
ALERT_URL=http://127.0.0.1:9000/alerts
