# Keeboarder server configuration
# One HTTP port serves both the REST API and the WebSocket endpoint (<context-path>/chat).
SERVER_ADDRESS=0.0.0.0
SERVER_PORT=8025
WEBSOCKET_CONTEXT_PATH=/keeboarder/ws
WEBSOCKET_ENABLED=true
REDIS_HOST=redis
REDIS_PORT=6379
AUTH_BASE_URL=http://auth-server/auth
KEEBOARDER_SERVER_ROUTE_PREFIX=/keeboarder/api
