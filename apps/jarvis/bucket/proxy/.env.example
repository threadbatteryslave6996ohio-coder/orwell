# Jarvis Bucket Proxy configuration
SERVER_PORT=5000

# Storage provider: aws or azure
PROXY_STORAGE_PROVIDER=aws
PROXY_STORAGE_MAX_FILE_SIZE=5368709120

# S3 settings
PROXY_S3_BUCKET_NAME=your-bucket-name
PROXY_S3_REGION=us-east-1
PROXY_S3_ENDPOINT=
PROXY_S3_PATH_STYLE_ACCESS=false
PROXY_S3_SSE=AES256

# Azure settings
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_CONTAINER=
AZURE_STORAGE_ENDPOINT=
AZURE_STORAGE_CONNECTION_STRING=

# Auth server
PROXY_AUTH_SERVER_BASE_URL=http://localhost:8081
AUTH_IDENTITY_PROVISIONING_KEY=

# Management dashboard
PROXY_MANAGEMENT_USERNAME=
PROXY_MANAGEMENT_PASSWORD=
PROXY_MANAGEMENT_SESSION_SECRET=

# CORS
PROXY_CORS_ALLOWED_ORIGINS=

# Logging
PROXY_LOGGING_AUDIT_FILE=logs/audit.log

# Server URL (used for secure cookie detection)
PROXY_SERVER_URL=
