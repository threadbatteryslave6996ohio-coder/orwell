# Jarvis bucket proxy — production environment
# Copy to .env.prod and fill in your production credentials.

PROXY_IMAGE_TAG=latest
PROXY_HOST_PORT=5000
SERVER_ADDRESS=0.0.0.0
SERVER_PORT=5000
PROXY_SERVER_URL=https://proxy.yourdomain.com

PROXY_STORAGE_PROVIDER=aws
PROXY_STORAGE_MAX_FILE_SIZE=5368709120

PROXY_S3_BUCKET_NAME=change-me
PROXY_S3_REGION=us-east-1
PROXY_S3_ENDPOINT=
PROXY_S3_PATH_STYLE_ACCESS=false
AWS_ACCESS_KEY_ID=change-me
AWS_SECRET_ACCESS_KEY=change-me

AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_CONTAINER=
AZURE_STORAGE_ENDPOINT=
AZURE_STORAGE_CONNECTION_STRING=
AZURE_CLIENT_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_SECRET=

AUTH_BASE_URL=http://auth.prod.internal:8081
AUTH_IDENTITY_PROVISIONING_KEY=change-me
PROXY_MANAGEMENT_USERNAME=change-me
PROXY_MANAGEMENT_PASSWORD=change-me
PROXY_MANAGEMENT_SESSION_SECRET=change-me
PROXY_CORS_ALLOWED_ORIGINS=https://yourdomain.com
