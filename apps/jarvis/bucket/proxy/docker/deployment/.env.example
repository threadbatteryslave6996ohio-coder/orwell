# Image and listener
PROXY_IMAGE_TAG=local
PROXY_HOST_PORT=5000
PROXY_SERVER_URL=http://localhost:5000

# Storage provider: aws or azure
PROXY_STORAGE_PROVIDER=aws
PROXY_STORAGE_MAX_FILE_SIZE=5368709120

# AWS/S3 configuration
PROXY_S3_BUCKET_NAME=replace-me
PROXY_S3_REGION=us-east-1
PROXY_S3_ENDPOINT=
PROXY_S3_PATH_STYLE_ACCESS=false
PROXY_S3_SSE=AES256
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# Azure configuration (used when PROXY_STORAGE_PROVIDER=azure)
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_CONTAINER=
AZURE_STORAGE_ENDPOINT=
AZURE_STORAGE_CONNECTION_STRING=
AZURE_CLIENT_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_SECRET=

# External auth server and proxy management
PROXY_AUTH_SERVER_BASE_URL=http://host.docker.internal:8081
AUTH_IDENTITY_PROVISIONING_KEY=
PROXY_MANAGEMENT_USERNAME=
PROXY_MANAGEMENT_PASSWORD=
PROXY_MANAGEMENT_SESSION_SECRET=
PROXY_CORS_ALLOWED_ORIGINS=
