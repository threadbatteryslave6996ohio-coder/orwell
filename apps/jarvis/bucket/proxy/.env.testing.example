# Jarvis bucket proxy — testing environment
# Copy to .env.testing and adjust as needed.

PROXY_IMAGE_TAG=local
PROXY_HOST_PORT=5000
PROXY_SERVER_URL=http://localhost:5000

PROXY_STORAGE_PROVIDER=aws
PROXY_STORAGE_MAX_FILE_SIZE=5368709120

PROXY_S3_BUCKET_NAME=test-bucket
PROXY_S3_REGION=us-east-1
PROXY_S3_ENDPOINT=http://localhost:9000
PROXY_S3_PATH_STYLE_ACCESS=true
PROXY_S3_SSE=AES256
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_SESSION_TOKEN=

AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_CONTAINER=
AZURE_STORAGE_ENDPOINT=
AZURE_STORAGE_CONNECTION_STRING=
AZURE_CLIENT_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_SECRET=

PROXY_AUTH_SERVER_BASE_URL=http://host.docker.internal:8081
AUTH_IDENTITY_PROVISIONING_KEY=test-key
PROXY_MANAGEMENT_USERNAME=admin
PROXY_MANAGEMENT_PASSWORD=admin
PROXY_MANAGEMENT_SESSION_SECRET=change-in-production
PROXY_CORS_ALLOWED_ORIGINS=*
