BACKUP_OUTPUT_DIR=backups
BACKUP_RETENTION_DAYS=30

BACKUP_PROJECTS=klippy,auth,secrets

BACKUP_KLIPPY_DATABASE_URL=postgresql://klippy:klippy@localhost:5432/klippy
BACKUP_KLIPPY_STORAGE_TYPE=directory

BACKUP_AUTH_DATABASE_URL=postgresql://auth:auth@localhost:5433/auth
BACKUP_AUTH_STORAGE_TYPE=directory

BACKUP_SECRETS_DATABASE_URL=postgresql://secrets:secrets@localhost:5435/secrets
BACKUP_SECRETS_STORAGE_TYPE=directory
