# Clippy — testing environment
# Hostnames reference docker service names in docker-compose.testing.yml.

# Auth server
AUTH_DATASOURCE_URL=jdbc:postgresql://db-auth/auth
AUTH_DATASOURCE_USERNAME=auth
AUTH_DATASOURCE_PASSWORD=auth
SERVER_ADDRESS=0.0.0.0
SERVER_PORT=80
LOGGING_FILE_NAME=logs/auth-server.log
AUTH_JPA_HIBERNATE_DDL_AUTO=update
AUTH_JPA_JDBC_TIME_ZONE=UTC

# Clipboard server
SPRING_DATASOURCE_URL=jdbc:postgresql://db-clippy/clippy
SPRING_DATASOURCE_USERNAME=clippy
SPRING_DATASOURCE_PASSWORD=clippy
SERVER_PORT=80
AUTH_BASE_URL=http://auth-server/auth
LOGGING_FILE_NAME=logs/klippy-server.log
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_PROPERTIES_HIBERNATE_JDBC_TIME_ZONE=UTC
