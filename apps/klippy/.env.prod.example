# Clippy — production environment
# Hostnames should point to your production database instances.
# No local databases are started in production mode.

# Auth server
AUTH_DATASOURCE_URL=jdbc:postgresql://your-auth-db-host:5432/auth?sslmode=require
AUTH_DATASOURCE_USERNAME=change-me
AUTH_DATASOURCE_PASSWORD=change-me
SERVER_ADDRESS=0.0.0.0
SERVER_PORT=80
LOGGING_FILE_NAME=logs/auth-server.log
AUTH_JPA_HIBERNATE_DDL_AUTO=validate
AUTH_JPA_JDBC_TIME_ZONE=UTC

# Clipboard server
SPRING_DATASOURCE_URL=jdbc:postgresql://your-clippy-db-host:5432/clippy?sslmode=require
SPRING_DATASOURCE_USERNAME=change-me
SPRING_DATASOURCE_PASSWORD=change-me
SERVER_PORT=80
AUTH_BASE_URL=http://auth-server/auth
LOGGING_FILE_NAME=logs/clippy-server.log
SPRING_JPA_HIBERNATE_DDL_AUTO=validate
SPRING_JPA_PROPERTIES_HIBERNATE_JDBC_TIME_ZONE=UTC
