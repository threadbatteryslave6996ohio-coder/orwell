# Configuration for the combined-server container (docker compose --profile combined).
# The combined launcher REQUIRES an env file (CLIPPY_ENV_FILE) and fails fast if
# it is missing. This file is mounted into the container and pointed at by
# CLIPPY_ENV_FILE in docker-compose.yml. Hostnames are docker network service names.

COMBINED_SERVER_PORT=8080

AUTH_DATASOURCE_URL=jdbc:postgresql://db-auth:5432/auth
AUTH_DATASOURCE_USERNAME=auth
AUTH_DATASOURCE_PASSWORD=auth

SPRING_DATASOURCE_URL=jdbc:postgresql://db-clippy:5432/clippy
SPRING_DATASOURCE_USERNAME=clippy
SPRING_DATASOURCE_PASSWORD=clippy

AUTH_JPA_HIBERNATE_DDL_AUTO=update
CLIPBOARD_JPA_HIBERNATE_DDL_AUTO=update
JPA_JDBC_TIME_ZONE=UTC

# The combined server validates tokens against its own /auth routes (same JVM).
CLIPPY_AUTH_BASE_URL=http://localhost:8080/auth
CLIPPY_AUTH_ROUTE_PREFIX=/auth
CLIPPY_SERVER_ROUTE_PREFIX=/api

LOGGING_FILE_NAME=logs/clippy-combined-server.log
