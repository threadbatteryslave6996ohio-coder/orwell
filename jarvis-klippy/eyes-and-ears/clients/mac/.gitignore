# Keeboarder macOS Client - Git Ignore
# Ignore local recordings and logs

# Recording files
*.mp4
*.wav
*.m4a

# Log files
*.log

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Temporary files
*.tmp
*.temp
/temp/

# AWS credentials (use ~/.aws/credentials instead)
.aws_credentials
aws_credentials.txt

# Local directories (created at runtime)
recordings/
scripts/

# Python cache
__pycache__/
*.py[cod]
*$py.class

# Node modules (if any Node tools added)
node_modules/
